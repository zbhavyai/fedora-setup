Host github.com
  HostName github.com
  IdentitiesOnly yes
  IdentityFile ~/.ssh/githubKey
  User git

Host bitbucket.org
  HostName bitbucket.org
  IdentitiesOnly yes
  IdentityFile ~/.ssh/bitbucketKey
  User git

Host localhost
 HostName localhost
 IdentitiesOnly yes
 Port 22
 IdentityFile ~/.ssh/githubKey

Host yankee
  HostName yankee
  IdentitiesOnly yes
  User root
  Port 22
  IdentityFile ~/.ssh/genericKey
  ForwardAgent yes

Host test*
  IdentitiesOnly yes
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

Host *
  IdentitiesOnly yes
  StrictHostKeyChecking no
  ForwardAgent yes
  IdentityFile ~/.ssh/genericKey
